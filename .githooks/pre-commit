#!/bin/bash

# Pre-commit hook for Hikearound React Native App
# Runs code quality checks before allowing commits

set -e

echo "[pre-commit] Running checks..."

export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"

# Source nvm if available
[ -s "$HOME/.nvm/nvm.sh" ] && \. "$HOME/.nvm/nvm.sh"

if command -v nvm >/dev/null 2>&1; then
    nvm use >/dev/null 2>&1 || true
fi

if ! command -v npm >/dev/null 2>&1; then
    echo "[pre-commit] ERROR: npm is not available in PATH"
    exit 1
fi

if [ ! -d "node_modules" ]; then
    echo "[pre-commit] Installing dependencies..."
    npm install
fi

echo "[pre-commit] Prettier check..."
if ! npm run format:check; then
    echo "[pre-commit] ERROR: Prettier formatting issues found. Run 'npm run format' to fix."
    exit 1
fi

echo "[pre-commit] ESLint..."
if ! npm run lint; then
    echo "[pre-commit] ERROR: ESLint issues found. Fix before committing."
    exit 1
fi

if command -v npx >/dev/null 2>&1 && npx expo --version >/dev/null 2>&1; then
    echo "[pre-commit] Expo dependency check..."
    if ! npx expo install --check; then
        echo "[pre-commit] ERROR: Expo dependency mismatch. Run 'npx expo install --fix' to resolve."
        exit 1
    fi
fi

echo "[pre-commit] OK"
